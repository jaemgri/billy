<h1>My Bills</h1>

<%= link_to "Add a new bill", new_bill_path %>

<%= month_calendar(events: @bills, attribute: :due_date) do |date, bills| %>
  <div class="day-number"><%= date.day %></div>

  <% bills.each do |bill| %>
    <div class="bill-item">
      <span><%= bill.name %></span>
      <span><%= number_to_currency(bill.amount) %></span>
    </div>
  <% end %>
<% end %>

<% @bills.each do |bill| %>
  <div>
    <h3><%= link_to bill.name, bill_path(bill) %></h3>
    <p><%= bill.category %> — ¥<%= bill.amount %></p>
    <p>Due: <%= bill.due_date %></p>
  </div>
<% end %>
