<div class="d-flex flex-column w-100">
  <!-- Header (Spans full width across top) -->

  <!-- Main Dashboard Container -->
  <div class="container-fluid p-0">
    <div class="row g-4" style="min-height: 80vh;">

      <!-- Calendar Column (Left / Main) -->
      <div class="col-12 col-lg-8">
        <div class="p-3 border rounded shadow-sm bg-white h-100">
          <%= month_calendar(events: @bills, attribute: :due_date) do |date, bills| %>
            <div class="day-number fw-bold"><%= date.day %></div>
            <% if bills.any? %>
              <div class="badge bg-danger rounded-pill mt-1">
                <%= bills.size %> <%= 'bill'.pluralize(bills.size) %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Upcoming Bills Sidebar Column (Right) -->
      <div class="col-12 col-lg-4">
        <div class="p-3 border rounded shadow-sm bg-white h-100 d-flex flex-column justify-content-between">
          <div>
            <h5 class="section-title mb-3 fw-bold">Due this month:</h5>

            <% if @due_this_month.any? %>
              <% @due_this_month.each do |bill| %>
                <%= link_to bill_path(bill), { class: "text-decoration-none" } do %>
                  <div class="bill-card mb-2 p-3 border rounded shadow-sm">
                    <div class="d-flex justify-content-between align-items-center w-100">
                      <div>
                        <div class="d-flex align-items-center">
                          <span class="bill-name fw-bold"><%= bill.name %></span>
                          <span class="badge bg-secondary ms-2"><%= bill.category %></span>
                        </div>
                        <div class="text-muted small">
                          Due <%= bill.due_date.strftime("%b %d") %> (<%= (bill.due_date - Date.today).to_i %> days)
                        </div>
                      </div>
                      <div class="fw-bold fs-5">
                        ¥<%= bill.amount %>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% end %>
            <% else %>
              <p class="text-muted italic">No bills due this month!</p>
            <% end %>
          </div>

          <!-- Total Calculation Footer -->
          <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
            <span class="fw-bold fs-5">Total:</span>
            <span class="fw-bold fs-4 text-primary">¥<%= @due_this_month.sum(&:amount) %></span>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
