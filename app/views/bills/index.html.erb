<!-- Header-->

<!-- Calendar-->
<div class="flex p-3 mt-3" style="height: 90vh;">

  <%= month_calendar(events: @bills, attribute: :due_date) do |date, bills| %>
    <div class="day-number"><%= date.day %></div>
    <% if bills.size > 0 %>
      <div><%= bills.size %></div>
    <% end %>
<!--
    <% bills.each do |bill| %>
      <div class="bill-item">
        <span><%= bill.name %></span>
        <span><%= number_to_currency(bill.amount) %></span>
      </div>
    <% end %>
-->
  <% end %>
<!-- Upcoming Bills/Due this month-->
 <div class="d-flex flex-row w-100 justify-content-between p-4">
  <div class="w-100">
    <h5 class="section-title mb-3">Due this month:</h5>

    <% @due_this_month.each do |bill| %>
      <div class="bill-card mb-2 p-3 border rounded shadow-sm">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="d-flex align-items-center">
              <span class="bill-name fw-bold"><%= bill.name %></span>
              <span class="badge bg-secondary ms-2"><%= bill.category %></span>
            </div>
            <div class="text-muted small">
              Due <%= bill.due_date.strftime("%b %d") %>
            </div>
          </div>
          <div class="fw-bold fs-5">
            ¥<%= bill.amount %>
          </div>
        </div>
      </div>
    <% end %>

    <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
      <span class="fw-bold fs-5">Total:</span>
      <span class="fw-bold fs-4 text-primary">¥<%= @due_this_month.sum(&:amount) %></span>
    </div>
  </div>
</div>
