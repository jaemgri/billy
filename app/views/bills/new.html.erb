<div class="new-bill-page">
  <h1 class="new-bill-title">Add a New Bill</h1>

  <%= form_with model: @bill, id: "new-bill-form" do |f| %>
    <div class="new-bill-form-card">
      <div class="form-group">
        <%= f.label :name %>
        <%= f.text_field :name, class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :description %>
        <%= f.text_area :description, class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :amount %>
        <%= f.number_field :amount, class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :category %>
        <%= f.text_field :category, class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :due_date %>
        <%= f.date_field :due_date, class: "form-input" %>
      </div>
    </div>

    <button type="button" class="btn-upload-bill">Upload a bill/bills (AI)...</button>

    <%= f.submit "Submit...", class: "btn-submit-bill" %>
  <% end %>
</div>
